{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "heart-rate-widget",
  "version": "1.0.0",
  "identifier": "com.heart-rate-widget.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "心率监测",
        "width": 320,
        "height": 220,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "alwaysOnTop": false,
        "transparent": true,
        "decorations": false,
        "center": false,
        "shadow": false,
        "dragDropEnabled": false,
        "visible": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": null
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
